---
import Button from "./Button.astro";
---

<div class="flex flex-col" id="contact">
  <div class="flex mb-[30px] md:mb-[80px] text-center items-center justify-center">
    <span class="text-[32px] md:text-5xl font-bold">Want to know more about our space?</span>
    <span class="hidden lg:flex font-bold text-5xl">&nbsp;Enquire now!</span>
  </div>
  
  <form id="hatch-form" class="text-secondary bg-white flex flex-col rounded-3xl max-w-[600px] w-full mx-auto px-[30px] py-[24px] md:py-[40px] gap-6">
    
    <div class="flex flex-col">
      <label for="fullName" class="text-xl font-semibold">Full name*</label>
      <input 
        type="text" 
        id="fullName" 
        name="fullName"
        class="outline-none border-b-2 border-primary py-2 focus:border-primary-dark transition-colors"
      />
    </div>

    <div class="flex flex-col">
      <label for="email" class="text-xl font-semibold">Email*</label>
      <input 
        type="email" 
        id="email" 
        name="email"
        class="outline-none border-b-2 border-primary py-2 focus:border-primary-dark transition-colors"
      />
    </div>

    <div class="flex flex-col mb-10">
      <label for="phone" class="text-xl font-semibold">Phone*</label>
      <input 
        type="tel" 
        id="phone" 
        name="phone"
        class="outline-none border-b-2 border-primary py-2 focus:border-primary-dark transition-colors"
      />
    </div>

    <div class="flex flex-col">
      <label for="interest" class="text-xl font-semibold">What are you interested in?*</label>
      <select
        id="interest"
        name="interest"
        class="outline-none border-b-2 border-primary py-2 focus:border-primary-dark transition-colors bg-white"
      >
        <option value="Free Trial">Free Trial</option>
        <option value="Dedicated Desk">Dedicated Desk</option>
        <option value="Private Office">Private Office</option>
      </select>
    </div>

    <div class="flex-col hidden" id="billing-wrapper">
      <label for="billing" class="text-xl font-semibold">Preferred Billing</label>
      <select
        id="billing"
        name="billing"
        class="outline-none border-b-2 border-primary py-2 focus:border-primary-dark transition-colors bg-white"
      >
        <option value="Monthly">Monthly</option>
        <option value="Quarterly">Quarterly</option>
        <option value="Yearly">Yearly</option>
      </select>
    </div>

    <div class="flex flex-col mb-10">
      <label for="enquiry" class="text-xl font-semibold">Enquiry:</label>
      <textarea
        id="enquiry"
        name="enquiry"
        rows="4"
        class="outline-none border-2 border-primary rounded-2xl p-3 mt-2 focus:border-primary-dark transition-colors resize-y"
      ></textarea>
    </div>

    <Button text="Submit" variant="primary" class="self-start text-xl! py-[17px]! px-[50px]!" type="submit"/>
    <p id="status" class="mt-4 hidden font-bold"></p>
  </form>
</div>

<script>
  import { actions } from 'astro:actions';

  const form = document.getElementById('hatch-form') as HTMLFormElement;
  const status = document.getElementById('status');
  const interest = document.getElementById('interest') as HTMLSelectElement;
  const billingWrapper = document.getElementById('billing-wrapper');

  function toggleBilling() {
    const show = interest.value !== 'Free Trial';
    billingWrapper?.classList.toggle('hidden', !show);
    billingWrapper?.classList.toggle('flex', show);
    (document.getElementById('billing') as HTMLSelectElement).disabled = !show;
  }

  interest?.addEventListener('change', toggleBilling);
  toggleBilling(); // set correct state on load

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);

    if (status) {
      status.textContent = "Submitting...";
      status.classList.remove('hidden', 'text-red-500', 'text-green-500');
    }

    const { data, error } = await actions.sendEnquiry(formData);

    if (error) {
      status!.textContent = "Error submitting enquiry.";
      status!.classList.add('text-red-500');
    } else {
      status!.textContent = "Submitted successfully!";
      status!.classList.add('text-green-500');
      form.reset();
      toggleBilling(); // re-sync after reset
    }
  });
</script>