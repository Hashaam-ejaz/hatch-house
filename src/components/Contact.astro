---
import Button from "./Button.astro";
---

<div class="flex flex-col" id="contact">
  <div class="flex mb-[30px] md:mb-[80px] text-center items-center justify-center">
    <span class="text-[32px] md:text-5xl font-bold">Want to know more about our space?</span>
    <span class="hidden lg:flex font-bold text-5xl">&nbsp;Enquire now!</span>
  </div>
  
  <form id="hatch-form" class="text-secondary bg-white flex flex-col rounded-3xl max-w-[600px] w-full mx-auto px-[30px] py-[54px] md:py-[100px] gap-6">
    
    <div class="flex flex-col">
      <label for="fullName" class="text-xl font-semibold">Full name*</label>
      <input 
        type="text" 
        id="fullName" 
        name="fullName"
        class="outline-none border-b-2 border-primary py-2 focus:border-primary-dark transition-colors"
      />
    </div>

    <div class="flex flex-col">
      <label for="email" class="text-xl font-semibold">Email*</label>
      <input 
        type="email" 
        id="email" 
        name="email"
        class="outline-none border-b-2 border-primary py-2 focus:border-primary-dark transition-colors"
      />
    </div>

    <div class="flex flex-col mb-10">
      <label for="phone" class="text-xl font-semibold">Phone*</label>
      <input 
        type="tel" 
        id="phone" 
        name="phone"
        class="outline-none border-b-2 border-primary py-2 focus:border-primary-dark transition-colors"
      />
    </div>

    <Button text="Submit" variant="primary" class="self-start text-xl! py-[17px]! px-[50px]!" type="submit"/>
    <p id="status" class="mt-4 hidden font-bold"></p>
  </form>
</div>

<script>
  import { actions } from 'astro:actions';

  const form = document.getElementById('hatch-form') as HTMLFormElement;
  const status = document.getElementById('status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    
    if (status) {
      status.textContent = "Submitting...";
      status.classList.remove('hidden', 'text-red-500', 'text-green-500');
    }

    const { data, error } = await actions.sendEnquiry(formData);

    if (error) {
      status!.textContent = "Error submitting enquiry.";
      status!.classList.add('text-red-500');
    } else {
      status!.textContent = "Submitted successfully!";
      status!.classList.add('text-green-500');
      form.reset();
    }
  });
</script>