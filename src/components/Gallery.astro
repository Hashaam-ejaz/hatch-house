---
import Button from "./Button.astro";

const images = [
  { src: '/site1.webp', alt: 'Main workspace view' },
  { src: '/site2.png', alt: 'Meeting area' },
  { src: '/site3.png', alt: 'Lounge area' },
  { src: '/site4.png', alt: 'Private cabins' },
];
---

<section class="text-white py-16 px-4 md:px-10">
  <div class="max-w-6xl mx-auto text-center mb-10">
    <div class="text-[32px] font-bold text-center mb-2.5 md:text-5xl">Our Site</div>
    <div class="text-center md:text-xl mb-[30px] md:mb-[80px]">Everything you need for productive and comfortable workdays</div>
  </div>

  <!-- Gallery Grid -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 max-w-5xl mx-auto" id="gallery">
    {images.map((img, index) => (
      <div 
        class:list={[
          "relative cursor-pointer overflow-hidden rounded-2xl transition-transform hover:scale-[1.01]",
          index === 0 ? "md:col-span-3" : "md:col-span-1"
        ]}
      >
        <img 
          src={img.src} 
          alt={img.alt} 
          data-index={index}
          class="gallery-img w-full h-full object-cover aspect-16/10 md:aspect-auto"
        />
        {index === 3 && (
          <a 
            href="/gallery" 
            class="absolute bottom-4 right-4 z-10 flex items-center gap-2 bg-white text-gray-900 px-4 py-2.5 rounded-md shadow-md hover:shadow-lg hover:scale-105 transition-colors text-sm font-medium"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="7" height="7"></rect>
              <rect x="14" y="3" width="7" height="7"></rect>
              <rect x="14" y="14" width="7" height="7"></rect>
              <rect x="3" y="14" width="7" height="7"></rect>
            </svg>
            View All Photos
          </a>
        )}
      </div>
    ))}
  </div>

</section>

