---
import { Image } from 'astro:assets';
const images = [
  { src: '/site1.webp', alt: 'Main workspace view' },
  { src: '/site2.png', alt: 'Meeting area' },
  { src: '/site3.png', alt: 'Lounge area' },
  { src: '/site4.png', alt: 'Private cabins' },
];
---

<section class="text-white py-16 px-4 md:px-10">
  <div class="max-w-6xl mx-auto text-center mb-10">
    <div class="text-[32px] font-bold text-center mb-2.5 md:text-5xl">Our Site</div>
    <div class="text-center md:text-xl mb-[30px] md:mb-[80px]">Everything you need for productive and comfortable workdays</div>
  </div>

  <!-- Gallery Grid -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 max-w-5xl mx-auto" id="gallery">
    {images.map((img, index) => (
      <div 
        class:list={[
          "relative cursor-pointer overflow-hidden rounded-2xl transition-transform hover:scale-[1.01]",
          index === 0 ? "md:col-span-3" : "md:col-span-1"
        ]}
      >
        <img 
          src={img.src} 
          alt={img.alt} 
          data-index={index}
          class="gallery-img w-full h-full object-cover aspect-[16/10] md:aspect-auto"
        />
      </div>
    ))}
  </div>

  <div 
    id="lightbox" 
    class="fixed inset-0 bg-black/90 z-50 hidden flex-col items-center justify-center p-4 md:p-10"
  >
    <!-- Close Button -->
    <button id="close-lightbox" class="absolute top-8 right-8 text-white text-4xl hover:text-gray-300">&times;</button>
    
    <!-- Prev Button -->
    <button id="prev-btn" class="absolute left-4 md:left-10 text-white text-5xl hover:scale-110">‹</button>
    
    <!-- Main Modal Image -->
    <img id="modal-img" src="" alt="" class="max-w-full max-h-[80vh] object-contain rounded-lg shadow-2xl" />
    
    <!-- Next Button -->
    <button id="next-btn" class="absolute right-4 md:right-10 text-white text-5xl hover:scale-110">›</button>
  </div>
</section>

<script>
  const gallery = document.getElementById('gallery');
  const lightbox = document.getElementById('lightbox');
  const modalImg = document.getElementById('modal-img') as HTMLImageElement;
  const closeBtn = document.getElementById('close-lightbox');
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');
  
  const images = Array.from(document.querySelectorAll('.gallery-img')) as HTMLImageElement[];
  let currentIndex = 0;

  function updateModalImage(index: number) {
    currentIndex = index;
    modalImg.src = images[currentIndex].src;
    modalImg.alt = images[currentIndex].alt;
  }

  function openLightbox(index: number) {
    if (window.innerWidth < 768) return;
    
    updateModalImage(index);
    lightbox?.classList.remove('hidden');
    lightbox?.classList.add('flex');
    document.body.style.overflow = 'hidden'; // Prevent scrolling
  }

  function closeLightbox() {
    lightbox?.classList.add('hidden');
    lightbox?.classList.remove('flex');
    document.body.style.overflow = 'auto';
  }

  function showNext() {
    currentIndex = (currentIndex + 1) % images.length;
    updateModalImage(currentIndex);
  }

  function showPrev() {
    currentIndex = (currentIndex - 1 + images.length) % images.length;
    updateModalImage(currentIndex);
  }

  gallery?.addEventListener('click', (e) => {
    const target = e.target as HTMLImageElement;
    if (target.classList.contains('gallery-img')) {
      const index = parseInt(target.dataset.index || '0');
      openLightbox(index);
    }
  });

  closeBtn?.addEventListener('click', closeLightbox);
  nextBtn?.addEventListener('click', (e) => { e.stopPropagation(); showNext(); });
  prevBtn?.addEventListener('click', (e) => { e.stopPropagation(); showPrev(); });

  // Close on clicking background
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (lightbox?.classList.contains('hidden')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowRight') showNext();
    if (e.key === 'ArrowLeft') showPrev();
  });
</script>