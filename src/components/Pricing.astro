---

<section class="pricing relative py-16 sm:py-20 lg:py-24" id="pricing">
  <div class="mx-auto w-full max-w-6xl px-4 sm:px-6">
    <!-- Heading -->
    <header class="text-center">
      <h2 class="text-[32px] font-bold tracking-tight text-white md:text-[48px]">
        Pick how you Pay. <span class="text-primary">Longer = Lower.</span>
      </h2>
      <p class="mt-2 text-[16px] text-white/60 md:text-[20px]">
        No hidden charges &amp; tax inclusive.
      </p>
    </header>

    <!-- Billing toggle -->
    <div class="mt-8 flex justify-center sm:mt-10">
      <div
        role="tablist"
        aria-label="Billing period"
        class="relative grid w-full max-w-md grid-cols-3 gap-1 rounded-full bg-white/10 p-1"
        data-toggle
      >
        <span
          aria-hidden="true"
          data-indicator
          class="pointer-events-none absolute bottom-1 top-1 rounded-full bg-primary transition-[left,width] duration-300 ease-out motion-reduce:transition-none"
        ></span>
        {
          periods.map((p, i) => (
            <button
              type="button"
              role="tab"
              data-tab={p.id}
              aria-selected={i === 0 ? "true" : "false"}
              aria-controls={`panel-${p.id}`}
              class="relative z-10 rounded-full py-2.5 text-sm font-semibold text-white/70 transition-colors duration-200 aria-selected:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-[#0a0a0a] cursor-pointer"
            >
              {p.label}
            </button>
          ))
        }
      </div>
    </div>

    <!-- Panels (one per billing period) -->
    {
      periods.map((p, pi) => (
        <div
          id={`panel-${p.id}`}
          role="tabpanel"
          data-panel={p.id}
          hidden={pi !== 0}
          class="mt-10 sm:mt-12"
        >
          {/* Carousel on mobile, grid on desktop */}
          <div
            data-carousel
            class:list={[
              "no-scrollbar flex snap-x snap-mandatory gap-4 overflow-x-auto scroll-px-4 px-4 pb-2 pt-4",
              "md:mx-auto md:grid md:gap-6 md:overflow-visible md:px-0 md:pb-0 md:pt-0",
              p.cols === 2 ? "md:max-w-4xl md:grid-cols-2" : "md:grid-cols-3",
            ]}
          >
            {p.plans.map((plan) => (
              <article
                class:list={[
                  "group relative flex shrink-0 snap-start flex-col rounded-2xl p-6 sm:p-7",
                  "w-[85%] sm:w-[60%] md:w-auto",
                  plan.highlighted
                    ? "border border-primary bg-white/[0.07] shadow-[0_0_0_1px_rgba(91,194,244,0.35),0_6px_18px_-10px_rgba(91,194,244,0.4)] md:shadow-[0_0_0_1px_rgba(91,194,244,0.35),0_20px_50px_-20px_rgba(91,194,244,0.45)]"
                    : "border border-white/10 bg-white/4",
                ]}
              >
                {plan.badge && (
                  <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-primary px-4 py-1 text-xs font-semibold text-white shadow-md">
                    {plan.badge}
                  </span>
                )}

                <h3 class="text-lg font-bold text-primary">{plan.name}</h3>

                {/* Price block */}
                <div class="mt-4 min-h-[4.75rem]">
                  {plan.eyebrow && (
                    <p class="text-[11px] font-semibold uppercase tracking-wider text-white/45">
                      {plan.eyebrow}
                    </p>
                  )}
                  {plan.oldPrice && (
                    <p class="text-xs font-medium uppercase tracking-wide text-white/35 line-through">
                      {plan.oldPrice}
                    </p>
                  )}
                  <p class="text-3xl font-extrabold leading-tight text-white sm:text-4xl">
                    {plan.price}
                  </p>
                  {plan.priceNote && (
                    <p class="mt-1 text-[11px] uppercase tracking-wide text-white/50">
                      {plan.priceNote}
                    </p>
                  )}
                </div>

                {/* Features */}
                <ul class="mt-5 space-y-3">
                  {plan.features.map((f) => (
                    <li class="flex items-start gap-2.5 text-sm text-white/75">
                      <svg
                        class="mt-0.5 h-4 w-4 shrink-0 text-primary"
                        width="16"
                        height="16"
                        viewBox="0 0 20 20"
                        fill="none"
                        aria-hidden="true"
                      >
                        <path
                          d="M4.5 10.5l3.5 3.5 7.5-8"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        />
                      </svg>
                      <span>{f}</span>
                    </li>
                  ))}
                </ul>

                {/* CTA + footnotes pinned to bottom for equal-height cards */}
                <div class="mt-auto pt-7">
                  <a
                    href="#"
                    class:list={[
                      "block w-full rounded-full py-3 text-center text-sm font-semibold transition-transform duration-150 hover:-translate-y-0.5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-offset-[#0a0a0a] motion-reduce:hover:translate-y-0",
                      plan.cta.style === "primary"
                        ? "bg-primary text-white hover:brightness-105 focus-visible:ring-primary"
                        : "bg-white text-[#0b0b0b] hover:bg-white/90 focus-visible:ring-white",
                    ]}
                  >
                    {plan.cta.label}
                  </a>

                  {plan.footnotes && (
                    <div class="mt-3 space-y-0.5">
                      {plan.footnotes.map((fn) => (
                        <p
                          class:list={[
                            "text-xs text-white/50",
                            fn.italic && "italic",
                          ]}
                        >
                          {fn.text}
                        </p>
                      ))}
                    </div>
                  )}
                </article>
            </div>

            ))}
        </div>

          {/* Dot indicators — mobile only */}
          {p.plans.length > 1 && (
            <div
              class="mt-5 flex justify-center gap-2 md:hidden"
              data-dots
              aria-hidden="true"
            >
              {p.plans.map((_, i) => (
                <button
                  type="button"
                  data-dot={i}
                  class="h-2 rounded-full bg-white/25 transition-all duration-200 data-[active]:w-6 data-[active]:bg-primary w-2"
                />
              ))}
            </div>
          )}
        </div>
      ))
    }
  </div>
</section>

<style>
  /* Hide scrollbar on the mobile carousel while keeping it scrollable */
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  function initPricing() {
    document.querySelectorAll<HTMLElement>(".pricing").forEach((root) => {
      if (root.dataset.init === "true") return;
      root.dataset.init = "true";

      const toggle = root.querySelector<HTMLElement>("[data-toggle]");
      const indicator = root.querySelector<HTMLElement>("[data-indicator]");
      const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-tab]"));
      const panels = Array.from(root.querySelectorAll<HTMLElement>("[data-panel]"));

      // --- Sliding toggle indicator ---
      function moveIndicator(btn: HTMLButtonElement | undefined) {
        if (!btn || !indicator || !toggle) return;
        indicator.style.left = `${btn.offsetLeft}px`;
        indicator.style.width = `${btn.offsetWidth}px`;
      }

      function activate(id: string) {
        const btn = tabs.find((t) => t.dataset.tab === id);
        tabs.forEach((t) =>
          t.setAttribute("aria-selected", t.dataset.tab === id ? "true" : "false")
        );
        panels.forEach((p) => (p.hidden = p.dataset.panel !== id));
        moveIndicator(btn);

        // Reset the now-visible carousel to the first card.
        const panel = panels.find((p) => p.dataset.panel === id);
        const carousel = panel?.querySelector<HTMLElement>("[data-carousel]");
        if (carousel) {
          carousel.scrollTo({ left: 0 });
          setActiveDot(panel!, 0);
        }
      }

      tabs.forEach((t) =>
        t.addEventListener("click", () => activate(t.dataset.tab!))
      );

      // Position the indicator under the initially-selected tab.
      const initial =
        tabs.find((t) => t.getAttribute("aria-selected") === "true") || tabs[0];
      requestAnimationFrame(() => moveIndicator(initial));
      window.addEventListener("resize", () =>
        moveIndicator(
          tabs.find((t) => t.getAttribute("aria-selected") === "true") || tabs[0]
        )
      );

      // --- Carousel dots ---
      function setActiveDot(panel: HTMLElement, index: number) {
        const dots = panel.querySelectorAll<HTMLElement>("[data-dot]");
        dots.forEach((d, i) => {
          if (i === index) d.setAttribute("data-active", "");
          else d.removeAttribute("data-active");
        });
      }

      panels.forEach((panel) => {
        const carousel = panel.querySelector<HTMLElement>("[data-carousel]");
        if (!carousel) return;
        const cards = Array.from(carousel.children) as HTMLElement[];
        const dots = panel.querySelectorAll<HTMLButtonElement>("[data-dot]");

        // Dot click → scroll that card into view.
        dots.forEach((dot, i) => {
          dot.addEventListener("click", () => {
            const card = cards[i];
            carousel.scrollTo({
              left: card.offsetLeft - carousel.offsetLeft,
              behavior: "smooth",
            });
          });
        });

        // Highlight the dot for whichever card is most in view.
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting && entry.intersectionRatio >= 0.55) {
                const idx = cards.indexOf(entry.target as HTMLElement);
                if (idx >= 0) setActiveDot(panel, idx);
              }
            });
          },
          { root: carousel, threshold: [0.55, 0.75] }
        );
        cards.forEach((c) => io.observe(c));
      });
    });
  }

  initPricing();
  // Re-run on Astro client-side navigation.
  document.addEventListener("astro:page-load", initPricing);
</script>