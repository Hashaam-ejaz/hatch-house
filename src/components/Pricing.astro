---
type CTAStyle = "primary" | "light";

interface Footnote {
  text: string;
  italic?: boolean;
}

interface Plan {
  name: string;
  highlighted?: boolean;
  badge?: string;        // shown on the top edge of highlighted cards
  eyebrow?: string;      // small label above the price (e.g. "Quarterly discount available")
  oldPrice?: string;     // struck-through reference price
  price: string;         // "Free" | "PKR 40,000" | "Custom"
  priceNote?: string;    // small caption under the price
  features: string[];
  cta: { label: string; style: CTAStyle };
  footnotes?: Footnote[];
}

interface Period {
  id: string;
  label: string;
  plans: Plan[];
  cols: 2 | 3; // desktop grid columns
}

const periods: Period[] = [
  {
    id: "monthly",
    label: "Monthly",
    cols: 3,
    plans: [
      {
        name: "One Day Trial",
        price: "Free",
        features: [
          "Work a full day on us.",
          "No card required.",
          "No commitment needed.",
          "Just show up.",
          "Valet Parking",
          "Power Back-Up",
          "Conference Room Access",
          "Rooftop Access",
          "Recreational Room Access",
        ],
        cta: { label: "Try a Day", style: "light" },
        footnotes: [{ text: "No Charges", italic: true }],
      },
      {
        name: "Dedicated Desk",
        highlighted: true,
        badge: "Most Popular",
        price: "PKR 40,000",
        priceNote: "Per month · Including tax · No hidden charges",
        features: [
          "Reserved Desk. Always Yours.",
          "Hatch Member Access Card",
          "Valet Parking",
          "Power Back-Up",
          "Private Locker",
          "Conference Room Access",
          "Rooftop Access",
          "Recreational Room Access",
          "Mail Handling",
        ],
        cta: { label: "Reserve My Desk", style: "primary" },
        footnotes: [{ text: "Tax inclusive · Cancel anytime", italic: true }],
      },
      {
        name: "Private Office",
        price: "Custom",
        priceNote: "For teams of 2–4",
        features: [
          "Priority Conference Room Slots",
          "Lockable Team Space",
          "Hatch Member Access Card",
          "Valet Parking",
          "Power Back-Up",
          "Rooftop Access",
          "Recreational Room Access",
          "Mail Handling",
          "Business Address & Logo",
        ],
        cta: { label: "Talk to Us", style: "light" },
        footnotes: [
          { text: "Everything in Dedicated Desk, plus team perks" },
          { text: "Tax inclusive, cancel with notice", italic: true },
        ],
      },
    ],
  },
  {
    id: "quarterly",
    label: "Quarterly",
    cols: 2,
    plans: [
      {
        name: "Dedicated Desk",
        highlighted: true,
        badge: "Most Popular",
        oldPrice: "PKR 40,000 / month",
        price: "PKR 30,000",
        priceNote: "Per month · Billed quarterly",
        features: [
          "25% saving vs monthly rate",
          "All Monthly features included",
          "Priority desk selection",
          "Locked-in rate guarantee",
        ],
        cta: { label: "Reserve My Desk", style: "primary" },
        footnotes: [
          { text: "Billed every 3 months · Cancel with notice" },
          { text: "Tax inclusive · No hidden charges", italic: true },
        ],
      },
      {
        name: "Private Office",
        eyebrow: "Quarterly discount available",
        price: "Custom",
        priceNote: "For teams of 2–4",
        features: [
          "All Private Office features",
          "Quarterly pricing discount",
          "Priority scheduling",
        ],
        cta: { label: "Talk to Us", style: "light" },
        footnotes: [{ text: "Ask us for a quarterly team quote.", italic: true }],
      },
    ],
  },
  {
