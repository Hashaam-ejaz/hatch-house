---
const reasons = [
  {
    logo: "/star.svg",
    heading: "Design Driven",
    text: "Every corner is thoughtfully designed to inspire creativity, and elevate your daily work experience.",
  },
  {
    logo: "/heart.svg",
    heading: "Community Focused",
    text: "We cultivate meaningful connections through curated events, and shared experiences.",
  },
  {
    logo: "/badge.svg",
    heading: "Premium Amenities",
    text: "High-speed internet, power back-up, ergonomic furniture, and top-tier facilities come as standard.",
  },
  {
    logo: "/lightning.svg",
    heading: "Flexibility",
    text: "Adapt your workspace to your needs with scalable solutions, and no long-term commitments.",
  },
  {
    logo: "/location.svg",
    heading: "Prime Location",
    text: "Strategically positioned in the heart of DHA with excellent transport links to all over the city.",
  },
];
---

<div class="flex flex-col py-12.5 md:py-25">
  <div class=" text-[32px] font-bold mb-2.5 text-center md:text-[48px]">
    Why Choose Hatch
  </div>
  <div class="text-base font-normal mb-7.5 md:mb-20 text-center md:text-[20px]">
    We are more than just a workspace. We are a community dedicated to helping
    you thrive.
  </div>
<div class="grid grid-cols-1 gap-5 md:grid-cols-6 lg:grid-cols-5">
    {
      reasons.map((reason, i) => (
        <div
          class:list={[
            "flex flex-col gap-2.5",
            // md: each card spans 2 of 6 cols (= 3 per row); reset to 1 col at lg
            "md:col-span-2 lg:col-span-1",
            // md (3+2): start orphan row (item 4) at col 2 → cards span 2–5, centered
            i === 3 && "md:col-start-2 lg:col-start-auto",
          ]}
        >
          <div class="w-10 h-10 flex items-center justify-start">
            <img
              src={reason.logo}
              alt={reason.heading}
              class="w-full h-full object-contain"
            />
          </div>
          <div class="font-semibold text-xl">{reason.heading}</div>
          <div class="text-base">{reason.text}</div>
        </div>
      ))
    }
  </div>
</div>
