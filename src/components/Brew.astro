---
import { Image } from 'astro:assets';
import brewPassImage from '../assets/brew.png'; 
---

<section class="bg-black text-white py-16 px-6 md:py-24" id="hatch-brew">
  <div class="max-w-[1200px] mx-auto flex flex-col items-center">
    
    <!-- Text Header Section -->
    <div class="text-center mb-10 md:mb-16">
      <h2 class="text-[32px] font-bold text-center mb-2.5 md:text-5xl">Hatch Brew</h2>
      <p class="text-center md:text-xl mb-[30px] md:mb-[80px]">
        Everything you need for productive and comfortable workdays
      </p>
    </div>

    <!-- Image Section -->
    <div class="w-full flex justify-center">
      <Image 
        src={brewPassImage} 
        alt="Hatch Brew Pass Infographic" 
        class="w-full h-auto rounded-[24px] md:rounded-[40px] shadow-2xl"
        quality="max"
        format="webp"
      />
    </div>

  </div>
</section>